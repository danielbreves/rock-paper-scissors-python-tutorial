{
    "name": "Python Tutorial",
    "image": "mcr.microsoft.com/devcontainers/python:3",
    "customizations": {
        "vscode": {
            "settings": {
                "github.copilot.enable": {
                    "*": false
                },
                "github.copilot.chat.agent.enabled": false,
                "github.codespaces.disableAIFeatures": true,
                "chat.commandCenter.enabled": false
            },
            "extensions": [
                "ms-python.python",
                "-github.copilot-chat"
            ]
        }
    }
}
